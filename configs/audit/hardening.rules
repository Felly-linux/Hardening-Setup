## =============================================================================
## /etc/audit/rules.d/hardening.rules
## Audit rules — VPS Hardening Suite (standard level)
## Loaded by modules/audit.sh when AUDITD_ENABLED=yes
## =============================================================================

## Remove all existing rules and start clean
-D

## Set buffer size (increase if audit daemon reports buffer overflows)
-b 8192

## Set failure mode: 1=log, 2=panic
-f 1

## =============================================================================
## Identity and authentication events
## =============================================================================

## User/group management
-w /etc/passwd -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/group -p wa -k identity
-w /etc/gshadow -p wa -k identity
-w /etc/sudoers -p wa -k sudoers
-w /etc/sudoers.d/ -p wa -k sudoers

## PAM configuration changes
-w /etc/pam.d/ -p wa -k pam

## Login configuration
-w /etc/login.defs -p wa -k login
-w /etc/securetty -p wa -k login
-w /var/log/faillog -p wa -k login
-w /var/log/lastlog -p wa -k login

## =============================================================================
## Privilege escalation
## =============================================================================

## sudo usage — key=sudo_exec for unambiguous SIEM correlation
-w /usr/bin/sudo -p x -k sudo_exec
-w /usr/bin/su -p x -k sudo_exec

## Execution of any setuid/setgid binary (privilege escalation via SUID)
## Captures: su, newgrp, pkexec, passwd, and any custom SUID binaries
-a always,exit -F arch=b64 -S setuid -S setgid -S setreuid -S setregid -k sudo_exec
-a always,exit -F arch=b32 -S setuid -S setgid -S setreuid -S setregid -k sudo_exec

## =============================================================================
## Filesystem and file access
## =============================================================================

## Unauthorised file access attempts (EACCES = permission denied, EPERM = not permitted)
-a always,exit -F arch=b64 -S creat -S open -S openat -S truncate -S ftruncate \
    -F exit=-EACCES -F auid>=1000 -F auid!=-1 -k access
-a always,exit -F arch=b64 -S creat -S open -S openat -S truncate -S ftruncate \
    -F exit=-EPERM -F auid>=1000 -F auid!=-1 -k access
-a always,exit -F arch=b32 -S creat -S open -S openat -S truncate -S ftruncate \
    -F exit=-EACCES -F auid>=1000 -F auid!=-1 -k access
-a always,exit -F arch=b32 -S creat -S open -S openat -S truncate -S ftruncate \
    -F exit=-EPERM -F auid>=1000 -F auid!=-1 -k access

## File deletion by users (generic — all locations)
-a always,exit -F arch=b64 -S unlink -S unlinkat -S rename -S renameat \
    -F auid>=1000 -F auid!=-1 -k delete
-a always,exit -F arch=b32 -S unlink -S unlinkat -S rename -S renameat \
    -F auid>=1000 -F auid!=-1 -k delete

## Delete or rename operations specifically on /etc — config_change key for SIEM
## An attacker deleting /etc/hosts or renaming /etc/sudoers is a strong IoC
-a always,exit -F arch=b64 -S unlink -S unlinkat -S rename -S renameat \
    -F dir=/etc -F auid>=0 -k config_change
-a always,exit -F arch=b32 -S unlink -S unlinkat -S rename -S renameat \
    -F dir=/etc -F auid>=0 -k config_change

## =============================================================================
## Mount operations
## =============================================================================
## Mounting a filesystem (especially with nosuid/noexec overrides removed)
## can bypass hardening applied to /tmp and other protected paths.
-a always,exit -F arch=b64 -S mount -F auid>=0 -k mount
-a always,exit -F arch=b32 -S mount -F auid>=0 -k mount
-a always,exit -F arch=b64 -S umount2 -F auid>=0 -k mount
-a always,exit -F arch=b32 -S umount -F auid>=0 -k mount

## =============================================================================
## Network configuration changes
## =============================================================================

-w /etc/hosts -p wa -k network
-w /etc/network/ -p wa -k network
-w /etc/NetworkManager/ -p wa -k network
-w /etc/resolv.conf -p wa -k network
-w /etc/sysconfig/network -p wa -k network

## sysctl network configuration — changing these files post-install could
## silently re-enable IP forwarding or undo hardened parameters
-w /etc/sysctl.d/ -p wa -k network

## =============================================================================
## System administration
## =============================================================================

## Cron job changes
-w /etc/cron.allow -p wa -k cron
-w /etc/cron.deny -p wa -k cron
-w /etc/cron.d/ -p wa -k cron
-w /etc/cron.daily/ -p wa -k cron
-w /etc/cron.hourly/ -p wa -k cron
-w /etc/cron.monthly/ -p wa -k cron
-w /etc/cron.weekly/ -p wa -k cron
-w /etc/crontab -p wa -k cron
-w /var/spool/cron/ -p wa -k cron
-w /var/spool/cron/crontabs/ -p wa -k cron

## SSH configuration and authorized keys
## authorized_keys changes can silently grant persistent access to an attacker
-w /etc/ssh/sshd_config -p wa -k sshd
-w /root/.ssh/authorized_keys -p wa -k sshd_auth
-w /home/ -p wa -k sshd_auth

## Systemd unit changes
-w /etc/systemd/ -p wa -k systemd
-w /lib/systemd/ -p wa -k systemd

## =============================================================================
## Kernel and module tampering
## =============================================================================

## Module loading/unloading
## File watches — execution of module management tools
-w /sbin/insmod -p x -k module_load
-w /sbin/rmmod -p x -k module_load
-w /sbin/modprobe -p x -k module_load
-w /sbin/kmod -p x -k module_load
-w /etc/modprobe.d/ -p wa -k module_load

## Syscall-level module load/unload — catches direct syscalls bypassing tools
## init_module/finit_module: load a kernel module from memory or fd
## delete_module: unload a kernel module (key=module_load for unified SIEM query)
-a always,exit -F arch=b64 -S init_module -S finit_module -k module_load
-a always,exit -F arch=b32 -S init_module -S finit_module -k module_load
-a always,exit -F arch=b64 -S delete_module -k module_load
-a always,exit -F arch=b32 -S delete_module -k module_load

## Kernel parameter changes — sysctl.d modifications could re-enable IP forwarding,
## disable ASLR, or weaken other hardened parameters after install
-w /etc/sysctl.conf -p wa -k sysctl
-w /etc/sysctl.d/ -p wa -k sysctl

## =============================================================================
## Audit infrastructure integrity
## =============================================================================

## Watch auditd configuration itself
-w /etc/audit/ -p wa -k audit_config
-w /etc/libaudit.conf -p wa -k audit_config
-w /etc/audisp/ -p wa -k audit_config

## =============================================================================
## Time changes (important for log integrity)
## =============================================================================

-a always,exit -F arch=b64 -S adjtimex -S settimeofday -S clock_settime -k time_change
-a always,exit -F arch=b32 -S adjtimex -S settimeofday -S clock_settime -k time_change
-w /etc/localtime -p wa -k time_change

## =============================================================================
## Lock audit configuration (immutable mode)
## Once loaded, rules cannot be changed until the next reboot.
## This prevents an attacker with root access from disabling auditing mid-attack.
## WARNING: Verify all rules are correct before enabling. Any mistake requires
## a reboot to fix. Disable this line during initial testing/tuning.
## =============================================================================
-e 2
