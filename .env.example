# =============================================================================
# .env.example — VPS Hardening Suite environment variables
# =============================================================================
# Copy this file to .env and fill in your values before running install.sh:
#   cp .env.example .env && nano .env
#
# .env is git-ignored. Never commit the actual .env file.
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────

# Grafana admin password. Change this — the default 'changeme' is not safe.
GRAFANA_PASSWORD=changeme

# SSH port. Module 03_ssh.sh will configure sshd and UFW to use this port.
# If you change it from 22, make sure to connect with: ssh -p PORT user@host
SSH_PORT=22

# ── Recommended ───────────────────────────────────────────────────────────────

# Non-root user to authorize for key-based SSH login.
# Leave blank to skip user creation / key configuration.
SSH_USER=

# Public hostname or IP for display in access URLs and Grafana server config.
# Defaults to auto-detected public IP if blank.
SERVER_DOMAIN=

# ── Optional ──────────────────────────────────────────────────────────────────

# Set to 1 to skip all interactive prompts. Useful for CI/CD or agent-driven
# deployments. All prompts default to their safe/recommended value.
NONINTERACTIVE=0

# Installation mode to use when --mode is not passed on the CLI.
# One of: basic | intermediate | hardcore | custom
INSTALL_MODE=intermediate

# CrowdSec LAPI listen port. Default: 6767 (moved from 8080 to avoid conflicts
# with cAdvisor and other common services).
CROWDSEC_LAPI_PORT=6767

# Directory where the monitoring stack files are deployed at runtime.
MONITORING_DIR=/opt/monitoring

# Set to 0 to skip automatic backups of system config files before modification.
# Not recommended — backups are the only easy recovery path.
BACKUP_CONFIGS=1

# Space-separated list of IPs that Fail2Ban will never ban.
# Always include your management/jump-box IP here.
# Example: WHITELIST_IPS="203.0.113.10 10.0.0.5"
WHITELIST_IPS=
